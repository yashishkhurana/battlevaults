# Battle Vaults — off-chain env. Copy to .env (gitignored) and fill in.

# --- Arc RPC ---
ARC_RPC_URL=https://rpc.testnet.arc.network

# --- LLM agent (OpenAI-compatible). Pick ONE free option. If LLM_BASE_URL is unset, the keeper
#     deterministically falls back to the rule engine, so the system still runs. ---

# Option A — Ollama (fully free, local, private; "self-hosted"):
#   ollama pull deepseek-r1:8b   (or qwen2.5:7b-instruct / llama3.1:8b)
LLM_BASE_URL=http://localhost:11434/v1
LLM_MODEL=deepseek-r1:8b
LLM_API_KEY=ollama

# Option B — OpenRouter free tier (hosted; free key at https://openrouter.ai/keys):
#   LLM_BASE_URL=https://openrouter.ai/api/v1
#   LLM_MODEL=deepseek/deepseek-r1:free
#   LLM_API_KEY=sk-or-...

# Option C — Groq free tier (fast; free key at https://console.groq.com):
#   LLM_BASE_URL=https://api.groq.com/openai/v1
#   LLM_MODEL=llama-3.3-70b-versatile
#   LLM_API_KEY=gsk_...

# set to "off" only if your provider returns 400 on response_format (JSON mode)
LLM_JSON_MODE=on

# optional: pin the full reasoning trace off-chain (IPFS/Irys gateway). Unset -> stub CID.
# IPFS_BASE_URL=https://your-gateway

# --- keeper signing (TESTNET burner keys only — never commit real keys) ---
STRATEGIST_PK=0x...      # the agent's keeper key (regime or carry, per run)
ORACLE_PK=0x...          # NAV pusher
EXECUTE=0                # set 1 to actually broadcast (default dry-run)

# --- NAV pricer ---
USYC_PRICE=1.0           # USDC per USYC (match the mock teller's price if you bump it)
EURUSD=1.08              # EUR/USD for the EURC sleeve
